<header class="navbar navbar-fixed-top navbar-inverse">
  <div class="container">
    <%= link_to "Assassin", root_path, id: "logo" %>
    <nav>
      <ul class="nav navbar-nav navbar-right">
        <li><%= link_to "Trang chủ", root_path %></li>
        <% if logged_in? %>
          <li><%= link_to "Danh sách", '#' %></li>
          <li><%= link_to "Thông tin cá nhân", current_user %></li>
          <li><%= link_to "Đăng xuất", logout_path, data: { turbo_method: :delete } %></li>
        <% else %>
          <li><%= link_to "Đăng nhập", login_path %></li>
        <% end %>
      </ul>
    </nav>
  </div>
</header>
