<% provide(:title, 'Trang cá nhân') %>

<div class="container mt-5">
  <h4 class="text-center mb-4">THAY ĐỔI THÔNG TIN</h4>
  <div class="row">
    <div class="col-md-3 text-center">
      <div class="mb-3">
        <img src="path/to/avatar.jpg" alt="Ảnh đại diện" class="img-thumbnail" style="width: 150px; height: 200px;">
        <p class="mt-2">Ảnh đại diện<br>4x6</p>
        <button class="btn btn-sm btn-outline-primary">Thêm ảnh</button>
        <button class="btn btn-sm btn-outline-secondary mt-1">Chỉnh sửa</button>
      </div>
    </div>
    <div class="col-md-9">
      <%= form_with model: @patient, local: true do |f| %>
      <%= render 'shared/error_messages', object: f.object%>
        <div class="mb-3">
          <%= f.label :name, "Họ và tên" %>
          <%= f.text_field :name, class: "form-control" %>
        </div>

        <div class="mb-3">
          <%= f.label :email %>
          <%= f.email_field :email, class: "form-control" %>
        </div>

        <div class="mb-3">
          <%= f.label :phone, "Số điện thoại" %>
          <%= f.telephone_field :phone, class: "form-control" %>
        </div>

        <div class="mb-3">
          <%= f.label :gender, "Giới tính" %><br>
          <div class="radio-group">
            <label class="radio-option">
              <%= f.radio_button :gender, 'male' %>
              <span>Nam</span>
            </label>
            <label class="radio-option">
              <%= f.radio_button :gender, 'female' %>
              <span>Nữ</span>
            </label>
          </div>
        </div>


        <div class="d-flex justify-content-between">
          <%= f.submit "Lưu thay đổi", class: "btn btn-success" %>
          <%= link_to "Hủy bỏ", root_path, class: "btn btn-secondary" %>
        </div>
      <% end %>
    </div>
  </div>
</div>